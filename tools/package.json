{
  "name": "@govschema/tools",
  "version": "0.1.0",
  "description": "Tooling for validating GovSchema documents in the registry.",
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "bin": {
    "govschema-validate": "./validate.mjs"
  },
  "scripts": {
    "validate": "node validate.mjs",
    "validate:schema": "node validate-ajv.mjs",
    "validate:all": "node validate.mjs && node validate-ajv.mjs"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "engines": {
    "node": ">=18"
  }
}
